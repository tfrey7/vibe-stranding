<idea-plugin>
    <id>dev.tfrey.vibe-stranding</id>
    <name>Vibe Stranding</name>
    <vendor>tfrey7</vendor>

    <description><![CDATA[
        The first strand-based vibe coding system. Declare a strand of work,
        develop it in its own git worktree and terminal tab, finish it onto
        main when done, and delete the workspace. One tab per strand.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Vibe Stranding" displayType="BALLOON"/>
        <httpRequestHandler implementation="dev.tfrey.vibestranding.mcp.HttpHandler"/>
        <toolWindow id="Vibe Stranding Summary"
                    anchor="right"
                    secondary="true"
                    icon="/icons/vibe-stranding.svg"
                    factoryClass="dev.tfrey.vibestranding.ui.StrandSummaryToolWindowFactory"/>
        <postStartupActivity implementation="dev.tfrey.vibestranding.ui.ResumeAllStrandsActivity"/>
        <postStartupActivity implementation="dev.tfrey.vibestranding.ui.StrandHandoffActivity"/>
        <postStartupActivity implementation="dev.tfrey.vibestranding.core.StrandDescriberStartupActivity"/>
        <projectConfigurable id="dev.tfrey.vibestranding.settings"
                             parentId="tools"
                             displayName="Vibe Stranding"
                             instance="dev.tfrey.vibestranding.ui.SettingsConfigurable"/>
        <!-- GitStrands and Settings are @Service(PROJECT); no registration needed. -->
    </extensions>

    <actions>
        <group id="VibeStranding.Menu" class="dev.tfrey.vibestranding.ui.MenuGroup" text="Vibe Stranding" popup="true" icon="/icons/vibe-stranding.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <!-- Also surface the group as a dropdown button on the Terminal
                 tool window's toolbar, so users don't have to dig into Tools. -->
            <add-to-group group-id="TerminalToolwindowActionGroup" anchor="last"/>
            <action id="VibeStranding.New"
                    class="dev.tfrey.vibestranding.ui.NewStrandAction"
                    text="New Strand..."
                    description="Create a worktree and terminal tab for a new strand of work"/>
            <action id="VibeStranding.CreateStrandFromTerminalSelection"
                    class="dev.tfrey.vibestranding.ui.CreateStrandFromTerminalSelectionAction"
                    text="Create Strand From Selection…"
                    description="Spawn a new strand seeded with the selected text in the focused terminal tab"
                    icon="/icons/vibe-stranding.svg"/>
            <group id="VibeStranding.Resume"
                   class="dev.tfrey.vibestranding.ui.ResumeStrandsGroup"
                   text="Resume Strand"/>
            <separator/>
            <action id="VibeStranding.ViewCode"
                    class="dev.tfrey.vibestranding.ui.ViewThisStrandsCodeAction"
                    text="View This Strand's Code"
                    description="Open the focused tab's strand worktree as a project in a new IDE window"/>
            <action id="VibeStranding.SummarizeThis"
                    class="dev.tfrey.vibestranding.ui.SummarizeThisStrandAction"
                    text="Summarize This Strand"
                    description="Ask the strand's claude session to summarize the work done so far"/>
            <action id="VibeStranding.FinishThis"
                    class="dev.tfrey.vibestranding.ui.FinishThisStrandAction"
                    text="Finish This Strand"
                    description="Land the strand owning the focused terminal tab onto the default branch, then delete it"/>
            <action id="VibeStranding.DeleteThis"
                    class="dev.tfrey.vibestranding.ui.DeleteThisStrandAction"
                    text="Delete This Strand"
                    description="Delete the strand owning the focused terminal tab without finishing it"/>
        </group>
        <action id="VibeStranding.CreateStrandFromSelection"
                class="dev.tfrey.vibestranding.ui.CreateStrandFromSelectionAction"
                text="Create Strand From Selection…"
                description="Spawn a new strand seeded with the selected text."
                icon="/icons/vibe-stranding.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ConsoleEditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
